#!/bin/sh
# ─── Git Safety Guard ────────────────────────────────────────────────────────
# Blocks commits that include .env files to prevent secret leaks.
# Configured via: git config core.hooksPath .githooks

ENV_FILES=$(git diff --cached --name-only | grep -E '^\\.env')

if [ -n "$ENV_FILES" ]; then
    echo ""
    echo "🚫 BLOCKED: Environment files cannot be committed."
    echo "   Remove them before pushing:"
    echo ""
    echo "$ENV_FILES" | sed 's/^/   → /'
    echo ""
    echo "   Run: git rm --cached <file>"
    echo ""
    exit 1
fi
