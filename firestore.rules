rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ["gauravpatil9262@gmail.com"];
    }

    // ─── Links ────────────────────────────────────────────────────────
    // All writes go through the admin SDK (server-side API routes).
    // Client reads are allowed for any authenticated user on their own links.
    match /links/{slug} {
      allow read: if true;  // Needed for redirect lookups
      allow list: if isAdmin();
      allow write: if false; // All writes via admin SDK
    }

    // ─── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if false; // All writes via admin SDK
    }

    // ─── Notifications (user scoped) ──────────────────────────────────
    match /users/{userId}/meta/notifications {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["unreadCount", "lastUpdated"])
        && request.resource.data.unreadCount is number
        && request.resource.data.unreadCount >= 0
        && request.resource.data.unreadCount <= resource.data.unreadCount;
      allow create, delete: if false;
    }
    match /notifications/{userId}/items/{notificationId} {
      allow read, list: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.read == true
        && resource.data.read == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["read", "updatedAt"]);
      allow create, delete: if false;
    }

    // ─── Admin Activity Streams (read-only) ─────────────────────────────
    match /transactions/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /orders/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /promo_codes/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /promo_redemptions/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /promo_activity/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /dev_flags/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /api_logs/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /activity_events/{docId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }

    // ─── Analytics ────────────────────────────────────────────────────
    // Read access requires authentication. Write access is admin SDK only.
    // Note: Server-side API routes use admin SDK which bypasses these rules.
    // Client reads are scoped by the API layer (getLinkAnalytics checks ownership).
    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // All writes via admin SDK
    }

    // ─── System (counters, config) ────────────────────────────────────
    match /system/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // ─── Default deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}