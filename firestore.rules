rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Links ────────────────────────────────────────────────────────
    // All writes go through the admin SDK (server-side API routes).
    // Client reads are allowed for any authenticated user on their own links.
    match /links/{slug} {
      allow read: if true;  // Needed for redirect lookups
      allow write: if false; // All writes via admin SDK
    }

    // ─── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // All writes via admin SDK
    }

    // ─── Analytics ────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // All writes via admin SDK
    }

    // ─── System (counters, config) ────────────────────────────────────
    match /system/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // ─── Default deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
